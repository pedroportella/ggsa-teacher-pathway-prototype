{
  "name": "@ggsa/portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <21.0.0",
    "pnpm": "10.18.3"
  },
  "scripts": {
    "predev": "node ../../scripts/check-node-version.mjs",
    "prebuild": "node ../../scripts/check-node-version.mjs",
    "prepreview": "node ../../scripts/check-node-version.mjs",
    "prestart": "node ../../scripts/check-node-version.mjs",
    "prelint": "node ../../scripts/check-node-version.mjs",
    "pretest": "node ../../scripts/check-node-version.mjs",
    "pretest:unit": "node ../../scripts/check-node-version.mjs",
    "pretest:e2e": "node ../../scripts/check-node-version.mjs",
    "pretest:e2e:headed": "node ../../scripts/check-node-version.mjs",
    "pretest:e2e:ui": "node ../../scripts/check-node-version.mjs",
    "pretest:e2e:debug": "node ../../scripts/check-node-version.mjs",
    "pretest:e2e:chromium": "node ../../scripts/check-node-version.mjs",
    "pretest:e2e:report": "node ../../scripts/check-node-version.mjs",
    "pretest:e2e:mock": "node ../../scripts/check-node-version.mjs",
    "pretest:e2e:real": "node ../../scripts/check-node-version.mjs",
    "pretest:e2e:real:headed": "node ../../scripts/check-node-version.mjs",
    "pretest:e2e:real:keep-records": "node ../../scripts/check-node-version.mjs",
    "pretypecheck": "node ../../scripts/check-node-version.mjs",
    "dev": "next dev -p 5174",
    "build": "next build",
    "preview": "next start -p 5173 -H 0.0.0.0",
    "start": "next start -p 5173 -H 0.0.0.0",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --project=chromium --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "PWDEBUG=1 playwright test --project=chromium --workers=1",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:report": "playwright show-report",
    "test:e2e:mock": "E2E_USE_MOCK=true playwright test",
    "test:e2e:real": "E2E_USE_MOCK=false E2E_CLEANUP_RECORDS=true playwright test --project=chromium --workers=1",
    "test:e2e:real:headed": "E2E_USE_MOCK=false E2E_CLEANUP_RECORDS=true playwright test --headed --project=chromium --workers=1",
    "test:e2e:real:keep-records": "E2E_USE_MOCK=false E2E_CLEANUP_RECORDS=false playwright test --project=chromium --workers=1"
  },
  "dependencies": {
    "@ggsa/services": "workspace:*",
    "@ggsa/ui-assets": "workspace:*",
    "@ggsa/ui-library": "workspace:*",
    "@ggsa/ui-tokens": "workspace:*",
    "@ggsa/utils": "workspace:*",
    "@health.gov.au/health-design-system": "^3.2.0",
    "lucide-react": "^0.468.0",
    "next": "15.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "eslint-config-next": "15.3.2"
  }
}
