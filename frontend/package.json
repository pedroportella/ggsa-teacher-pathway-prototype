{
  "name": "ggsa-teacher-pathway-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GGSA frontend workspace with portal apps and reusable design packages.",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @ggsa/portal dev",
    "build": "pnpm -r --filter './packages/**' build && pnpm --filter @ggsa/portal build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r --filter './packages/**' test && pnpm --filter @ggsa/portal test:unit",
    "test:e2e": "pnpm --filter @ggsa/portal test:e2e",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^18.19.74",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.3.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^24.1.3",
    "sass": "^1.83.4",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "vitest": "^1.6.1"
  }
}
