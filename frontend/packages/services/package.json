{
  "name": "@ggsa/services",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <21.0.0",
    "pnpm": "10.18.3"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
