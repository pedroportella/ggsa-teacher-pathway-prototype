{
  "name": "@ggsa/ui-library",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <21.0.0",
    "pnpm": "10.18.3"
  },
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/theme/styles.css"
  },
  "scripts": {
    "prebuild": "node ../../scripts/check-node-version.mjs",
    "pretypecheck": "node ../../scripts/check-node-version.mjs",
    "prelint": "node ../../scripts/check-node-version.mjs",
    "pretest": "node ../../scripts/check-node-version.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ggsa/ui-assets": "workspace:*",
    "@ggsa/ui-tokens": "workspace:*",
    "@ggsa/utils": "workspace:*",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
