{
  "name": "ggsa-teacher-pathway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GGSA Teacher Pathway portal using Next.js, headless WordPress, adapter-ready pathway data and Docker.",
  "packageManager": "pnpm@10.18.3",
  "volta": {
    "node": "20.19.5",
    "pnpm": "10.18.3"
  },
  "engines": {
    "node": ">=20.19.0 <23.0.0",
    "pnpm": "10.18.3"
  },
  "scripts": {
    "dev": "pnpm --dir frontend dev",
    "build": "pnpm --dir frontend build",
    "lint": "pnpm --dir frontend lint",
    "php:install": "composer --working-dir=backend/wp-content/plugins/ggsa-teacher-pathway install",
    "php:lint": "composer --working-dir=backend/wp-content/plugins/ggsa-teacher-pathway run lint",
    "php:cs": "composer --working-dir=backend/wp-content/plugins/ggsa-teacher-pathway run phpcs",
    "php:stan": "composer --working-dir=backend/wp-content/plugins/ggsa-teacher-pathway run phpstan",
    "php:test": "composer --working-dir=backend/wp-content/plugins/ggsa-teacher-pathway run test",
    "php:quality": "composer --working-dir=backend/wp-content/plugins/ggsa-teacher-pathway run quality",
    "backend:setup:local": "sh scripts/local-backend-setup.sh",
    "backend:start:local": "sh scripts/local-backend-start.sh",
    "test": "pnpm --dir frontend test",
    "test:unit": "pnpm --dir frontend test:unit",
    "test:e2e": "pnpm --dir frontend test:e2e",
    "test:e2e:real": "pnpm --dir frontend test:e2e:real",
    "test:e2e:local:real": "sh scripts/test-e2e-local-real.sh",
    "typecheck": "pnpm --dir frontend typecheck",
    "docker:build": "docker compose build wordpress frontend",
    "docker:up": "sh scripts/docker-up.sh",
    "docker:up:seed": "sh scripts/docker-up.sh --refresh-register",
    "docker:logs": "docker compose logs -f",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v",
    "docker:clean": "docker compose down -v --rmi local --remove-orphans",
    "docker:fresh": "pnpm docker:clean && pnpm docker:build && pnpm docker:up:seed"
  }
}
